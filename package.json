{
  "name": "eslint-config-expensify",
  "version": "2.0.107",
  "description": "Expensify's ESLint configuration following our style guide",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Expensify/eslint-config-expensify.git"
  },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "eslint .",
    "postinstall": "patch-package"
  },
  "type": "module",
  "dependencies": {
    "@babel/core": "^8.0.0-rc.2",
    "@babel/eslint-parser": "^8.0.0-rc.2",
    "@typescript-eslint/parser": "^8.56.1",
    "@typescript-eslint/utils": "^8.56.1",
    "confusing-browser-globals": "^1.0.11",
    "eslint": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^15.14.0",
    "lodash": "^4.17.21",
    "typescript": "^5.0.0",
    "underscore": "^1.13.6"
  },
  "files": [
    "eslint-plugin-expensify",
    "patches",
    "rules",
    "sample-props.js",
    "index.js"
  ],
  "keywords": [
    "eslint",
    "eslintconfig",
    "config",
    "javascript",
    "styleguide",
    "expensify"
  ],
  "author": "Florian Weber <florian@expensify.com>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Expensify/eslint-config-expensify/issues"
  },
  "homepage": "https://github.com/Expensify/eslint-config-expensify#readme",
  "devDependencies": {
    "@typescript-eslint/rule-tester": "^8.56.1",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/eslint-plugin-expensify/fixtures/"
    ]
  },
  "overrides": {
    "eslint-plugin-import": {
      "eslint": "^10.0.0"
    },
    "eslint-plugin-react": {
      "eslint": "^10.0.0"
    },
    "eslint-plugin-jsx-a11y": {
      "eslint": "^10.0.0"
    },
    "eslint-plugin-react-hooks": {
      "eslint": "^10.0.0"
    }
